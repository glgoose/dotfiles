#!/usr/bin/env bash
# lec-normalize — two-pass loudnorm for a single WAV file
# Usage: lec-normalize <file.wav>
# Targets: -16 LUFS integrated, -1 dBTP true peak, LRA 9
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: lec-normalize <file.wav>"
  exit 1
fi

FILE="$1"

if [[ ! -f "$FILE" ]]; then
  echo "Error: file not found: $FILE"
  exit 1
fi

if ! command -v ffmpeg &>/dev/null; then
  echo "Error: ffmpeg not found. Install with: brew install ffmpeg"
  exit 1
fi
if ! command -v jq &>/dev/null; then
  echo "Error: jq not found. Install with: brew install jq"
  exit 1
fi

echo "  Analyzing $FILE..."

# Pass 1 — measure loudness; ffmpeg writes the JSON stats to stderr
STATS=$(ffmpeg -i "$FILE" \
  -af "loudnorm=I=-16:TP=-1:LRA=9:print_format=json" \
  -f null - 2>&1)

# Extract the JSON block that ffmpeg prints after "Parsed_loudnorm" and parse with jq
JSON=$(echo "$STATS" | grep -A20 'Parsed_loudnorm' | tail -n +2 | jq -s '.[0]')

input_i=$(     echo "$JSON" | jq -r '.input_i')
input_tp=$(    echo "$JSON" | jq -r '.input_tp')
input_lra=$(   echo "$JSON" | jq -r '.input_lra')
input_thresh=$(echo "$JSON" | jq -r '.input_thresh')
target_offset=$(echo "$JSON" | jq -r '.target_offset')

echo "  Applying normalization to $FILE..."

TMPFILE="${FILE%.wav}_loudnorm_tmp.wav"

# Pass 2 — apply measured correction using linear mode for minimal artifacts
ffmpeg -y -i "$FILE" \
  -af "loudnorm=I=-16:TP=-1:LRA=9:\
measured_I=${input_i}:measured_TP=${input_tp}:measured_LRA=${input_lra}:\
measured_thresh=${input_thresh}:offset=${target_offset}:\
linear=true:print_format=summary" \
  "$TMPFILE" 2>/dev/null

mv "$TMPFILE" "$FILE"
echo "  Done: $FILE"
