#!/usr/bin/env bash
# bench-asr — compare ASR engines on a single WAV file
#
# Engines:
#   whisper-mlx        mlx-community/whisper-large-v3-turbo-4bit
#   whisper-cpp        ggml-large-v3-turbo-q5_0  (brew install whisper-cpp)
#   parakeet-mlx       parakeet-tdt-0.6b-v2  (uvx parakeet-mlx)
#   audio-qwen3-0.6B   Qwen3-ASR-0.6B  (audio transcribe)
#   audio-qwen3-0.6B-8b
#   audio-qwen3-1.7B-4b
#
# Usage: bench-asr [-c] [--lang CODE] <audio.wav>
#   -c / --cache   skip engines that already have output files
#
# Outputs (all flat in ./bench-<name>/):
#   <name>.<engine>.txt / .srt    transcripts
#   <name>.<engine>.time          saved runtime
#   results.csv                   one line per run, appended across runs
set -uo pipefail

LANG_CODE="en"
USE_CACHE=false
FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --lang) [[ $# -lt 2 ]] && { echo "Error: --lang requires a language code"; exit 1; }
            LANG_CODE="$2"; shift 2 ;;
    -c|--cache) USE_CACHE=true; shift ;;
    -*) echo "Unknown option: $1"; echo "Usage: bench-asr [-c] [--lang CODE] <audio.wav>"; exit 1 ;;
    *) FILE="$1"; shift ;;
  esac
done

if [[ -z "$FILE" || ! -f "$FILE" ]]; then
  echo "Usage: bench-asr [-c] [--lang CODE] <audio.wav>"
  exit 1
fi

NAME="$(basename "${FILE%.*}")"
FILE="$(cd "$(dirname "$FILE")" && pwd)/$(basename "$FILE")"
OUT="$(pwd)/bench-${NAME}"
mkdir -p "$OUT"
CSV="$OUT/results.csv"
[[ ! -f "$CSV" ]] && echo "date,engine,model,time,words,dup%" > "$CSV"

# ── Helpers ────────────────────────────────────────────────────────────────────

words()   { wc -w < "$1" | tr -d ' '; }

dup_pct() {
  python3 - "$1" <<'PY'
import sys, collections
lines = [l.strip() for l in open(sys.argv[1]) if l.strip()]
total = len(lines)
if total == 0: print("0%"); sys.exit()
c = collections.Counter(lines)
dups = sum(v - 1 for v in c.values() if v > 1)
print(f"{round(100 * dups / total)}%")
PY
}

T_START=0
tick()      { T_START=$(date +%s); }
tock()      { echo $(( $(date +%s) - T_START )); }
save_time() { echo "${1}s" > "$2"; }
load_time() { cat "$1" 2>/dev/null || echo "?"; }

declare -a RES_ENGINE RES_MODEL RES_TIME RES_WORDS RES_DUP RES_NOTE

record() {
  local engine="$1" model="$2" elapsed="$3" txt="$4" note="$5"
  local w="-" d="-"
  [[ -f "$txt" ]] && { w=$(words "$txt"); d=$(dup_pct "$txt"); }
  RES_ENGINE+=("$engine"); RES_MODEL+=("$model"); RES_TIME+=("$elapsed")
  RES_WORDS+=("$w"); RES_DUP+=("$d"); RES_NOTE+=("$note")
  # append to CSV for completed runs only
  [[ -f "$txt" && "$elapsed" != "-" ]] && \
    echo "$(date +%F),${engine},${model},${elapsed},${w},${d}" >> "$CSV"
}

# ── Engine 1: whisper-mlx ──────────────────────────────────────────────────────
MLX_TXT="$OUT/${NAME}.whisper-mlx.txt"
MLX_TIME="$OUT/${NAME}.whisper-mlx.time"

echo ""
echo "── whisper-mlx (large-v3-turbo-4bit) ────────────────────────────────────────"
if [[ "$USE_CACHE" == true && -f "$MLX_TXT" ]]; then
  echo "  cached"
  record "whisper-mlx" "large-v3-turbo-4bit" "$(load_time "$MLX_TIME")" "$MLX_TXT" ""
elif command -v mlx_whisper &>/dev/null; then
  TMPDIR=$(mktemp -d)
  tick
  if mlx_whisper "$FILE" \
      --model "mlx-community/whisper-large-v3-turbo-4bit" \
      --language "$LANG_CODE" \
      --output-format all \
      --output-name "$NAME" \
      --output-dir "$TMPDIR" \
      --condition-on-previous-text False \
      --verbose False; then
    ELAPSED=$(tock)
    mv "$TMPDIR/${NAME}.txt" "$OUT/${NAME}.whisper-mlx.txt"
    [[ -f "$TMPDIR/${NAME}.srt" ]] && mv "$TMPDIR/${NAME}.srt" "$OUT/${NAME}.whisper-mlx.srt"
    save_time "$ELAPSED" "$MLX_TIME"
    echo "  Done in ${ELAPSED}s"
    record "whisper-mlx" "large-v3-turbo-4bit" "${ELAPSED}s" "$MLX_TXT" ""
  else
    ELAPSED=$(tock); echo "  FAILED after ${ELAPSED}s"
    record "whisper-mlx" "large-v3-turbo-4bit" "${ELAPSED}s" "-" "failed"
  fi
  rm -rf "$TMPDIR"
else
  echo "  SKIP — mlx_whisper not found (uv tool install mlx-whisper)"
  record "whisper-mlx" "large-v3-turbo-4bit" "-" "-" "not installed"
fi

# ── Engine 2: whisper.cpp + Metal ──────────────────────────────────────────────
CPP_MODEL_FILE="ggml-large-v3-turbo-q5_0.bin"
CPP_MODEL="$(brew --prefix)/share/whisper-cpp/$CPP_MODEL_FILE"
CPP_TXT="$OUT/${NAME}.whisper-cpp.txt"
CPP_TIME="$OUT/${NAME}.whisper-cpp.time"

echo ""
echo "── whisper.cpp + Metal (large-v3-turbo-q5_0) ────────────────────────────────"
if [[ "$USE_CACHE" == true && -f "$CPP_TXT" ]]; then
  echo "  cached"
  record "whisper-cpp" "large-v3-turbo-q5_0" "$(load_time "$CPP_TIME")" "$CPP_TXT" ""
elif ! command -v whisper-cli &>/dev/null; then
  echo "  SKIP — whisper-cli not found (brew install whisper-cpp)"
  record "whisper-cpp" "large-v3-turbo-q5_0" "-" "-" "not installed"
elif [[ ! -f "$CPP_MODEL" ]]; then
  echo "  SKIP — model not found: $CPP_MODEL"
  printf '  Download: curl -L -o "%s" \\\n    "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/%s"\n' \
    "$CPP_MODEL" "$CPP_MODEL_FILE"
  record "whisper-cpp" "large-v3-turbo-q5_0" "-" "-" "model missing"
else
  # whisper-cli appends .txt/.srt to --output-file base
  TMPBASE=$(mktemp -d)/out
  tick
  if whisper-cli -m "$CPP_MODEL" -f "$FILE" -l "$LANG_CODE" \
      --output-srt --output-txt --output-file "$TMPBASE" 2>/dev/null; then
    ELAPSED=$(tock)
    mv "${TMPBASE}.txt" "$CPP_TXT"
    [[ -f "${TMPBASE}.srt" ]] && mv "${TMPBASE}.srt" "$OUT/${NAME}.whisper-cpp.srt"
    save_time "$ELAPSED" "$CPP_TIME"
    echo "  Done in ${ELAPSED}s"
    record "whisper-cpp" "large-v3-turbo-q5_0" "${ELAPSED}s" "$CPP_TXT" ""
  else
    ELAPSED=$(tock); echo "  FAILED after ${ELAPSED}s"
    record "whisper-cpp" "large-v3-turbo-q5_0" "${ELAPSED}s" "-" "failed"
  fi
fi

# ── Engine 3: parakeet-mlx ─────────────────────────────────────────────────────
PAR_TXT="$OUT/${NAME}.parakeet-mlx.txt"
PAR_TIME="$OUT/${NAME}.parakeet-mlx.time"

echo ""
echo "── parakeet-mlx (parakeet-tdt-0.6b-v2) ─────────────────────────────────────"
if [[ "$USE_CACHE" == true && -f "$PAR_TXT" ]]; then
  echo "  cached"
  record "parakeet-mlx" "parakeet-tdt-0.6b-v2" "$(load_time "$PAR_TIME")" "$PAR_TXT" ""
elif ! command -v uvx &>/dev/null; then
  echo "  SKIP — uvx not found (brew install uv)"
  record "parakeet-mlx" "parakeet-tdt-0.6b-v2" "-" "-" "not installed"
else
  TMPWORK=$(mktemp -d)
  cp "$FILE" "$TMPWORK/$NAME.wav"
  tick
  if (cd "$TMPWORK" && uvx parakeet-mlx "$NAME.wav" --output-format all 2>/dev/null); then
    ELAPSED=$(tock)
    mv "$TMPWORK/${NAME}.txt" "$PAR_TXT"
    [[ -f "$TMPWORK/${NAME}.srt" ]] && mv "$TMPWORK/${NAME}.srt" "$OUT/${NAME}.parakeet-mlx.srt"
    save_time "$ELAPSED" "$PAR_TIME"
    echo "  Done in ${ELAPSED}s"
    record "parakeet-mlx" "parakeet-tdt-0.6b-v2" "${ELAPSED}s" "$PAR_TXT" ""
  else
    ELAPSED=$(tock); echo "  FAILED after ${ELAPSED}s"
    record "parakeet-mlx" "parakeet-tdt-0.6b-v2" "${ELAPSED}s" "-" "failed"
  fi
  rm -rf "$TMPWORK"
fi

# ── Engines 4–6: audio transcribe (Qwen3-ASR) ────────────────────────────────
# Skipped for 8 GB M1: qwen3/1.7B full precision (~3.4 GB)

run_audio() {
  local label="$1" engine="$2" model="$3"
  local SLUG="audio-${label}"
  local OUT_TXT="$OUT/${NAME}.${SLUG}.txt"
  local OUT_TIME="$OUT/${NAME}.${SLUG}.time"
  local DISPLAY="${engine}${model:+/}${model}"

  echo ""
  echo "── ${SLUG} (${DISPLAY}) $(printf '─%.0s' {1..40})" | head -c 80; echo

  if [[ "$USE_CACHE" == true && -f "$OUT_TXT" ]]; then
    echo "  cached"
    record "$SLUG" "$DISPLAY" "$(load_time "$OUT_TIME")" "$OUT_TXT" ""
    return
  fi

  if ! command -v audio &>/dev/null; then
    echo "  SKIP — audio CLI not found"
    record "$SLUG" "$DISPLAY" "-" "-" "not installed"
    return
  fi

  local ARGS=("$FILE" --engine "$engine")
  [[ -n "$model" ]] && ARGS+=(--model "$model")
  [[ "$LANG_CODE" != "en" ]] && ARGS+=(--language "$LANG_CODE")

  tick
  if audio transcribe "${ARGS[@]}" > "$OUT_TXT" 2>/dev/null; then
    ELAPSED=$(tock)
    save_time "$ELAPSED" "$OUT_TIME"
    echo "  Done in ${ELAPSED}s"
    record "$SLUG" "$DISPLAY" "${ELAPSED}s" "$OUT_TXT" ""
  else
    ELAPSED=$(tock)
    rm -f "$OUT_TXT"
    echo "  FAILED after ${ELAPSED}s"
    record "$SLUG" "$DISPLAY" "${ELAPSED}s" "-" "failed"
  fi
}

run_audio "qwen3-0.6B"    "qwen3" "0.6B"
run_audio "qwen3-0.6B-8b" "qwen3" "0.6B-8bit"
run_audio "qwen3-1.7B-4b" "qwen3" "1.7B-4bit"

# ── Summary table ──────────────────────────────────────────────────────────────
echo ""
echo "── Results ───────────────────────────────────────────────────────────────────"
printf "  %-22s %-22s %6s %6s %6s  %s\n" "Engine" "Model" "Time" "Words" "Dup%" "Note"
printf "  %s\n" "$(python3 -c "print('─' * 86)")"
for i in "${!RES_ENGINE[@]}"; do
  printf "  %-22s %-22s %6s %6s %6s  %s\n" \
    "${RES_ENGINE[$i]}" "${RES_MODEL[$i]}" "${RES_TIME[$i]}" \
    "${RES_WORDS[$i]}" "${RES_DUP[$i]}" "${RES_NOTE[$i]}"
done
echo ""
echo "  Dup% = duplicate lines / total — 0% clean, high % = hallucination loop"
echo "  Language: $LANG_CODE  |  Log: $CSV"
