#!/usr/bin/env bash
# bench-asr — compare ASR engines on a single WAV file
#
# Engines tested:
#   whisper-mlx          mlx-community/whisper-large-v3-turbo-4bit
#   whisper.cpp+Metal    ggml-large-v3-turbo-q5_0  (brew install whisper-cpp)
#   parakeet-mlx         parakeet-tdt-0.6b-v2  (uvx parakeet-mlx)
#   audio/qwen3-0.6B     Qwen3-ASR-0.6B  (audio transcribe)
#   audio/qwen3-0.6B-8b  Qwen3-ASR-0.6B-8bit
#   audio/qwen3-1.7B-4b  Qwen3-ASR-1.7B-4bit  (~850 MB, fits 8 GB)
#
# Usage: bench-asr [--lang CODE] <audio.wav>
# Outputs: ./bench-<name>/<engine>/{name}.srt, {name}.txt
# Summary: time taken, word count, dup% (hallucination proxy)
set -uo pipefail

LANG_CODE="en"
FILE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --lang) [[ $# -lt 2 ]] && { echo "Error: --lang requires a language code"; exit 1; }
            LANG_CODE="$2"; shift 2 ;;
    -*) echo "Unknown option: $1"; echo "Usage: bench-asr [--lang CODE] <audio.wav>"; exit 1 ;;
    *)  FILE="$1"; shift ;;
  esac
done

if [[ -z "$FILE" || ! -f "$FILE" ]]; then
  echo "Usage: bench-asr [--lang CODE] <audio.wav>"
  exit 1
fi

NAME="$(basename "${FILE%.*}")"
FILE="$(cd "$(dirname "$FILE")" && pwd)/$(basename "$FILE")"  # absolute path
OUT="$(pwd)/bench-${NAME}"
mkdir -p "$OUT"

# ── Helpers ────────────────────────────────────────────────────────────────────

words() { wc -w < "$1" | tr -d ' '; }

# Duplicate-line % (hallucination proxy): 0% = clean, high = repetition loop
dup_pct() {
  python3 - "$1" <<'PY'
import sys, collections
lines = [l.strip() for l in open(sys.argv[1]) if l.strip()]
total = len(lines)
if total == 0: print("0%"); sys.exit()
c = collections.Counter(lines)
dups = sum(v - 1 for v in c.values() if v > 1)
print(f"{round(100 * dups / total)}%")
PY
}

T_START=0
tick() { T_START=$(date +%s); }
tock() { echo $(( $(date +%s) - T_START )); }

declare -a RES_ENGINE RES_MODEL RES_TIME RES_WORDS RES_DUP RES_NOTE

record() {
  local engine="$1" model="$2" elapsed="$3" txt="$4" note="$5"
  RES_ENGINE+=("$engine")
  RES_MODEL+=("$model")
  RES_TIME+=("$elapsed")
  if [[ -f "$txt" ]]; then
    RES_WORDS+=("$(words "$txt")")
    RES_DUP+=("$(dup_pct "$txt")")
  else
    RES_WORDS+=("-")
    RES_DUP+=("-")
  fi
  RES_NOTE+=("$note")
}

# ── Engine 1: whisper-mlx ──────────────────────────────────────────────────────
MLX_MODEL="mlx-community/whisper-large-v3-turbo-4bit"
MLX_OUT="$OUT/whisper-mlx"
mkdir -p "$MLX_OUT"

echo ""
echo "── whisper-mlx (large-v3-turbo-4bit) ────────────────────────────────────────"
if [[ -f "$MLX_OUT/${NAME}.txt" ]]; then
  echo "  CACHED — using existing output"
  record "whisper-mlx" "large-v3-turbo-4bit" "(cached)" "$MLX_OUT/${NAME}.txt" ""
elif command -v mlx_whisper &>/dev/null; then
  tick
  if mlx_whisper "$FILE" \
    --model "$MLX_MODEL" \
    --language "$LANG_CODE" \
    --output-format all \
    --output-name "$NAME" \
    --output-dir "$MLX_OUT" \
    --condition-on-previous-text False \
    --verbose False; then
    ELAPSED=$(tock)
    echo "  Done in ${ELAPSED}s"
    record "whisper-mlx" "large-v3-turbo-4bit" "${ELAPSED}s" "$MLX_OUT/${NAME}.txt" ""
  else
    ELAPSED=$(tock)
    echo "  FAILED after ${ELAPSED}s"
    record "whisper-mlx" "large-v3-turbo-4bit" "${ELAPSED}s" "-" "failed"
  fi
else
  echo "  SKIP — mlx_whisper not found (uv tool install mlx-whisper)"
  record "whisper-mlx" "large-v3-turbo-4bit" "-" "-" "not installed"
fi

# ── Engine 2: whisper.cpp + Metal ──────────────────────────────────────────────
CPP_MODEL_FILE="ggml-large-v3-turbo-q5_0.bin"
CPP_MODELS_DIR="$(brew --prefix)/share/whisper-cpp"
CPP_MODEL="$CPP_MODELS_DIR/$CPP_MODEL_FILE"
CPP_OUT="$OUT/whisper-cpp"
mkdir -p "$CPP_OUT"

echo ""
echo "── whisper.cpp + Metal (large-v3-turbo-q5_0) ────────────────────────────────"
if [[ -f "$CPP_OUT/${NAME}.txt" ]]; then
  echo "  CACHED — using existing output"
  record "whisper.cpp+Metal" "large-v3-turbo-q5_0" "(cached)" "$CPP_OUT/${NAME}.txt" ""
elif ! command -v whisper-cli &>/dev/null; then
  echo "  SKIP — whisper-cli not found (brew install whisper-cpp)"
  record "whisper.cpp+Metal" "large-v3-turbo-q5_0" "-" "-" "not installed"
elif [[ ! -f "$CPP_MODEL" ]]; then
  echo "  SKIP — model not found: $CPP_MODEL"
  printf '  Download: curl -L -o "%s" \\\n    "https://huggingface.co/ggerganov/whisper.cpp/resolve/main/%s"\n' \
    "$CPP_MODEL" "$CPP_MODEL_FILE"
  record "whisper.cpp+Metal" "large-v3-turbo-q5_0" "-" "-" "model missing"
else
  tick
  if whisper-cli \
    -m "$CPP_MODEL" \
    -f "$FILE" \
    -l "$LANG_CODE" \
    --output-srt \
    --output-txt \
    --output-file "$CPP_OUT/$NAME" \
    2>/dev/null; then
    ELAPSED=$(tock)
    echo "  Done in ${ELAPSED}s"
    record "whisper.cpp+Metal" "large-v3-turbo-q5_0" "${ELAPSED}s" "$CPP_OUT/${NAME}.txt" ""
  else
    ELAPSED=$(tock)
    echo "  FAILED after ${ELAPSED}s"
    record "whisper.cpp+Metal" "large-v3-turbo-q5_0" "${ELAPSED}s" "-" "failed"
  fi
fi

# ── Engine 3: parakeet-mlx (uvx) ──────────────────────────────────────────────
PAR_MODEL="parakeet-tdt-0.6b-v2"
PAR_OUT="$OUT/parakeet-mlx"
mkdir -p "$PAR_OUT"

echo ""
echo "── parakeet-mlx (parakeet-tdt-0.6b-v2) ─────────────────────────────────────"
if [[ -f "$PAR_OUT/${NAME}.txt" ]]; then
  echo "  CACHED — using existing output"
  record "parakeet-mlx" "$PAR_MODEL" "(cached)" "$PAR_OUT/${NAME}.txt" ""
elif ! command -v uvx &>/dev/null; then
  echo "  SKIP — uvx not found (brew install uv)"
  record "parakeet-mlx" "$PAR_MODEL" "-" "-" "not installed"
else
  TMPWORK=$(mktemp -d)
  cp "$FILE" "$TMPWORK/$NAME.wav"
  tick
  if (cd "$TMPWORK" && uvx parakeet-mlx "$NAME.wav" --output-format all 2>/dev/null); then
    ELAPSED=$(tock)
    [[ -f "$TMPWORK/${NAME}.srt" ]] && mv "$TMPWORK/${NAME}.srt" "$PAR_OUT/${NAME}.srt"
    [[ -f "$TMPWORK/${NAME}.txt" ]] && mv "$TMPWORK/${NAME}.txt" "$PAR_OUT/${NAME}.txt"
    rm -rf "$TMPWORK"
    echo "  Done in ${ELAPSED}s"
    record "parakeet-mlx" "$PAR_MODEL" "${ELAPSED}s" "$PAR_OUT/${NAME}.txt" ""
  else
    ELAPSED=$(tock)
    rm -rf "$TMPWORK"
    echo "  FAILED after ${ELAPSED}s"
    record "parakeet-mlx" "$PAR_MODEL" "${ELAPSED}s" "-" "failed"
  fi
fi

# ── Engines 4–6: audio transcribe (Qwen3-ASR variants) ───────────────────────
# Models skipped for 8 GB M1: qwen3/1.7B (full precision, ~3.4 GB)
# qwen3-coreml requires a separately compiled .mlmodelc — skipped unless present

run_audio() {
  local label="$1" engine="$2" model="$3"
  local ENGINE_OUT="$OUT/audio-${label}"
  mkdir -p "$ENGINE_OUT"

  echo ""
  if [[ -n "$model" ]]; then
    echo "── audio/${label} (engine=${engine}, model=${model}) $(printf '─%.0s' {1..30})"
  else
    echo "── audio/${label} (engine=${engine}) $(printf '─%.0s' {1..40})"
  fi

  if [[ -f "$ENGINE_OUT/${NAME}.txt" ]]; then
    echo "  CACHED — using existing output"
    record "audio/${label}" "${engine}${model:+/}${model}" "(cached)" "$ENGINE_OUT/${NAME}.txt" ""
    return
  fi

  if ! command -v audio &>/dev/null; then
    echo "  SKIP — audio CLI not found"
    record "audio/${label}" "${engine}${model:+/}${model}" "-" "-" "not installed"
    return
  fi

  local ARGS=("$FILE" --engine "$engine")
  [[ -n "$model" ]] && ARGS+=(--model "$model")
  [[ -n "$LANG_CODE" && "$LANG_CODE" != "en" ]] && ARGS+=(--language "$LANG_CODE")

  tick
  if audio transcribe "${ARGS[@]}" > "$ENGINE_OUT/${NAME}.txt" 2>/dev/null; then
    ELAPSED=$(tock)
    echo "  Done in ${ELAPSED}s"
    record "audio/${label}" "${engine}${model:+/}${model}" "${ELAPSED}s" "$ENGINE_OUT/${NAME}.txt" ""
  else
    ELAPSED=$(tock)
    rm -f "$ENGINE_OUT/${NAME}.txt"
    echo "  FAILED after ${ELAPSED}s"
    record "audio/${label}" "${engine}${model:+/}${model}" "${ELAPSED}s" "-" "failed"
  fi
}

run_audio "qwen3-0.6B"     "qwen3"    "0.6B"
run_audio "qwen3-0.6B-8b"  "qwen3"    "0.6B-8bit"
run_audio "qwen3-1.7B-4b"  "qwen3"    "1.7B-4bit"

# ── Summary table ──────────────────────────────────────────────────────────────
echo ""
echo "── Results ───────────────────────────────────────────────────────────────────"
printf "  %-22s %-22s %6s %6s %6s  %s\n" "Engine" "Model" "Time" "Words" "Dup%" "Note"
printf "  %s\n" "$(python3 -c "print('─' * 86)")"
for i in "${!RES_ENGINE[@]}"; do
  printf "  %-22s %-22s %6s %6s %6s  %s\n" \
    "${RES_ENGINE[$i]}" "${RES_MODEL[$i]}" "${RES_TIME[$i]}" \
    "${RES_WORDS[$i]}" "${RES_DUP[$i]}" "${RES_NOTE[$i]}"
done
echo ""
echo "  Dup% = duplicate lines as % of total — 0% = clean, high % = hallucination loop"
echo "  Skipped for 8 GB M1: qwen3/1.7B (full precision, ~3.4 GB)"
echo "  Language: $LANG_CODE"
echo ""
echo "  Review outputs:  open $OUT"
