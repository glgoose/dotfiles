#!/usr/bin/env python3
# lec-lightning-transcribe — thin wrapper around the lightning-whisper-mlx Python API
# Usage: lec-lightning-transcribe <audio_file> <model> <batch_size>
# Called by lec-benchmark; not intended for direct use.
import sys
from lightning_whisper_mlx import LightningWhisperMLX

audio_path = sys.argv[1]
model      = sys.argv[2]
batch_size = int(sys.argv[3])

w      = LightningWhisperMLX(model=model, batch_size=batch_size)
result = w.transcribe(audio_path=audio_path)
print(result["text"])
