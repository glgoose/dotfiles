#!/usr/bin/env bash
# lec-process — transcribe lecture WAV files, optionally renaming, correcting, diarizing
# Usage: lec-process [-r|--rename] [-e|--engine whisper|parakeet] [-l|--lang LANGCODE] [-c|--correct] [-d|--diarize] [-p|--provider openai|anthropic]
# Run from inside the lecture folder (e.g. "260402 feminism")
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Defaults ───────────────────────────────────────────────────────────────────
RENAME=false
LANG_CODE="en"
CORRECT=false
DIARIZE=false
PROVIDER="openai"
LANG_SET=false
ENGINE="whisper"

# ── Argument parsing ───────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --rename|-r)
      RENAME=true
      shift
      ;;
    --lang|-l)
      [[ $# -lt 2 ]] && { echo "Error: --lang requires a language code (e.g. --lang nl, --lang fr, --lang de)"; exit 1; }
      LANG_CODE="$2"
      LANG_SET=true
      shift 2
      ;;
    --correct|-c)
      CORRECT=true
      shift
      ;;
    --diarize|-d)
      DIARIZE=true
      shift
      ;;
    --provider|-p)
      [[ $# -lt 2 ]] && { echo "Error: --provider requires openai or anthropic"; exit 1; }
      PROVIDER="$2"
      shift 2
      ;;
    --engine|-e)
      [[ $# -lt 2 ]] && { echo "Error: --engine requires whisper or parakeet"; exit 1; }
      ENGINE="$2"
      [[ "$ENGINE" != "whisper" && "$ENGINE" != "parakeet" ]] && {
        echo "Error: --engine must be 'whisper' or 'parakeet'"; exit 1; }
      shift 2
      ;;
    -h|--help)
      echo "Usage: lec-process [-r|--rename] [-e|--engine whisper|parakeet] [-l|--lang LANGCODE] [-c|--correct] [-d|--diarize] [-p|--provider openai|anthropic]"
      echo "       LANGCODE examples: nl (Dutch), fr (French), de (German), es (Spanish), it (Italian), zh (Chinese), ko (Korean), ja (Japanese)"
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: lec-process [-r|--rename] [-e|--engine whisper|parakeet] [-l|--lang LANGCODE] [-c|--correct] [-d|--diarize] [-p|--provider openai|anthropic]"
      echo "       LANGCODE examples: nl (Dutch), fr (French), de (German), es (Spanish), it (Italian), zh (Chinese), ko (Korean), ja (Japanese)"
      exit 1
      ;;
  esac
done

# Parakeet is English-only
if [[ "$ENGINE" == "parakeet" && "$LANG_SET" == true ]]; then
  echo "Error: --engine parakeet is English-only; --lang is not supported."
  exit 1
fi

# ── Dependency checks ──────────────────────────────────────────────────────────
if ! command -v uv &>/dev/null; then
  echo "Error: uv not found. Install with: brew install uv"
  exit 1
fi

# ── Collect FLAC/WAV files, prefer FLAC when both share a stem ────────────────
AUDIO_FILES=()
FLAC_STEMS=()

while IFS= read -r f; do
  AUDIO_FILES+=("$f")
  FLAC_STEMS+=("${f%.*}")
done < <(find . -maxdepth 1 -iname "*.flac" | sed 's|^\./||' | sort)

while IFS= read -r f; do
  stem="${f%.*}"
  skip=false
  for s in "${FLAC_STEMS[@]+"${FLAC_STEMS[@]}"}"; do
    [[ "$s" == "$stem" ]] && { skip=true; break; }
  done
  [[ "$skip" == false ]] && AUDIO_FILES+=("$f")
done < <(find . -maxdepth 1 -iname "*.wav" | sed 's|^\./||' | sort)

IFS=$'\n' AUDIO_FILES=($(printf '%s\n' "${AUDIO_FILES[@]+"${AUDIO_FILES[@]}"}" | sort))
unset IFS

if [[ ${#AUDIO_FILES[@]} -eq 0 ]]; then
  echo "Error: no .wav or .flac files found in the current directory."
  exit 1
fi

SCRIPT_START=$(date +%s)

# ── Rename (optional) ─────────────────────────────────────────────────
if [[ "$RENAME" == true ]]; then
  FOLDER_NAME="$(basename "$PWD")"
  echo ""
  echo "── Rename ──────────────────────────────────────────────────────────"

  INDEX=1
  RENAMED=()
  for FILE in "${AUDIO_FILES[@]}"; do
    EXT="${FILE##*.}"
    TARGET="${FOLDER_NAME}_${INDEX}.${EXT}"
    if [[ "$FILE" == "$TARGET" ]]; then
      echo "  [skip] $FILE"
    else
      mv "$FILE" "$TARGET"
      echo "  $FILE → $TARGET"
    fi
    RENAMED+=("$TARGET")
    INDEX=$((INDEX + 1))
  done

  # Re-sort after rename (names are now deterministic)
  AUDIO_FILES=()
  while IFS= read -r f; do
    AUDIO_FILES+=("$f")
  done < <(printf '%s\n' "${RENAMED[@]}" | sort)
fi

# ── Transcribe ────────────────────────────────────────────────────────
echo ""
echo "── Transcribe ──────────────────────────────────────────────────────"

# 4-bit quantized: ~463 MB on disk, much lower memory than the full model (~1.6 GB),
# negligible accuracy loss. Better fit for 8 GB unified memory.
MLX_MODEL="mlx-community/whisper-large-v3-turbo-4bit"

format_duration() {
  awk -v s="$1" 'BEGIN{
    h=int(s/3600); m=int((s%3600)/60)
    if (h>0) printf "%dh%02dm", h, m
    else     printf "%dm", m
  }'
}

FILES_PROCESSED=0
TOTAL_AUDIO=0

for FILE in "${AUDIO_FILES[@]}"; do
  DURATION=$(ffprobe -v quiet -show_entries format=duration -of csv=p=0 "$FILE" 2>/dev/null | awk '{printf "%d", $1}')
  TOTAL_AUDIO=$((TOTAL_AUDIO + DURATION))
  NAME="${FILE%.*}"
  echo "  Transcribing $FILE..."
  FILE_START=$(date +%s)

  if [[ "$ENGINE" == "whisper" ]]; then
    # Output to a temp dir so we can pick only .srt and .txt
    TMPDIR=$(mktemp -d)
    uvx --from mlx-whisper mlx_whisper "$FILE" \
      --model "$MLX_MODEL" \
      --language "$LANG_CODE" \
      --output-format all \
      --output-name "$NAME" \
      --output-dir "$TMPDIR" \
      --condition-on-previous-text False \
      --verbose False

    mv "$TMPDIR/${NAME}.srt" "./${NAME}.srt"
    mv "$TMPDIR/${NAME}.txt" "./${NAME}.txt"
    rm -rf "$TMPDIR"
  else
    # parakeet-mlx writes srt/txt to cwd directly
    uvx parakeet-mlx "$FILE" --output-format all
  fi

  FILE_END=$(date +%s)
  echo "  Done in $((FILE_END - FILE_START))s → ${NAME}.srt, ${NAME}.txt"
  FILES_PROCESSED=$((FILES_PROCESSED + 1))
done

# ── Correct (optional) ────────────────────────────────────────────────
if [[ "$CORRECT" == true ]]; then
  echo ""
  echo "── Correct ─────────────────────────────────────────────────────────"
  "$SCRIPT_DIR/lec-correct" --provider "$PROVIDER"
fi

# ── Diarize (optional) ────────────────────────────────────────────────
if [[ "$DIARIZE" == true ]]; then
  echo ""
  echo "── Diarize ─────────────────────────────────────────────────────────"
  for FILE in "${AUDIO_FILES[@]}"; do
    NAME="${FILE%.*}"
    "$SCRIPT_DIR/lec-diarize" "$FILE" "${NAME}.srt"
  done
fi

# ── Summary ───────────────────────────────────────────────────────────────────
SCRIPT_END=$(date +%s)
TOTAL=$((SCRIPT_END - SCRIPT_START))

STEPS="transcribe"
[[ "$RENAME"   == true ]] && STEPS="rename, $STEPS"
[[ "$CORRECT"  == true ]] && STEPS="$STEPS, correct"
[[ "$DIARIZE"  == true ]] && STEPS="$STEPS, diarize"

echo ""
echo "── Summary ─────────────────────────────────────────────────────────────────"
printf "  %-18s %s\n" "Files processed:" "$FILES_PROCESSED"
printf "  %-18s %s\n" "Steps run:"       "$STEPS"
printf "  %-18s %s\n" "Language:"        "$LANG_CODE"
printf "  %-18s %s\n" "Engine:"          "$ENGINE"
[[ "$ENGINE" == "whisper" ]] && printf "  %-18s %s\n" "Model:" "$MLX_MODEL"
printf "  %-18s %s\n" "Total audio:"     "$(format_duration "$TOTAL_AUDIO")"
printf "  %-18s %s\n" "Speed:"           "$(awk -v a="$TOTAL_AUDIO" -v p="$TOTAL" 'BEGIN{printf "x%.1f", a/p}')"
printf "  %-18s %s\n" "Total time:"      "$(awk -v t="$TOTAL" 'BEGIN{printf "%.1fm (%ds)", t/60, t}')"
