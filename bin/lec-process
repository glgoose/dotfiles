#!/usr/bin/env bash
# lec-process — transcribe lecture WAV files, optionally renaming and correcting
# Usage: lec-process [--rename|-r] [--lang|-l LANGCODE] [--correct|-c] [--context "string"]
# Run from inside the lecture folder (e.g. "260402 feminism")
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ── Defaults ───────────────────────────────────────────────────────────────────
RENAME=false
LANG_CODE="en"
CORRECT=false
CONTEXT_STR=""

# ── Argument parsing ───────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --rename|-r)
      RENAME=true
      shift
      ;;
    --lang|-l)
      [[ $# -lt 2 ]] && { echo "Error: --lang requires a language code (e.g. --lang nl)"; exit 1; }
      LANG_CODE="$2"
      shift 2
      ;;
    --correct|-c)
      CORRECT=true
      shift
      ;;
    --context)
      [[ $# -lt 2 ]] && { echo "Error: --context requires a string argument"; exit 1; }
      CONTEXT_STR="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: lec-process [--rename|-r] [--lang|-l LANGCODE] [--correct|-c] [--context \"string\"]"
      exit 1
      ;;
  esac
done

# ── Dependency checks ──────────────────────────────────────────────────────────
if ! command -v mlx_whisper &>/dev/null; then
  echo "Error: mlx_whisper not found. Install with: uv tool install mlx-whisper"
  exit 1
fi

# ── Collect WAV files, sorted alphabetically ──────────────────────────────────
WAV_FILES=()
while IFS= read -r f; do
  WAV_FILES+=("$f")
done < <(find . -maxdepth 1 -iname "*.wav" | sed 's|^\./||' | sort)

if [[ ${#WAV_FILES[@]} -eq 0 ]]; then
  echo "Error: no .wav files found in the current directory."
  exit 1
fi

SCRIPT_START=$(date +%s)

# ── Step 1: Rename (optional) ─────────────────────────────────────────────────
if [[ "$RENAME" == true ]]; then
  FOLDER_NAME="$(basename "$PWD")"
  echo ""
  echo "── Step 1: Rename ──────────────────────────────────────────────────────────"

  INDEX=1
  RENAMED=()
  for FILE in "${WAV_FILES[@]}"; do
    TARGET="${FOLDER_NAME}_${INDEX}.wav"
    if [[ "$FILE" == "$TARGET" ]]; then
      echo "  [skip] $FILE"
    else
      mv "$FILE" "$TARGET"
      echo "  $FILE → $TARGET"
    fi
    RENAMED+=("$TARGET")
    INDEX=$((INDEX + 1))
  done

  # Re-sort after rename (names are now deterministic)
  WAV_FILES=()
  while IFS= read -r f; do
    WAV_FILES+=("$f")
  done < <(printf '%s\n' "${RENAMED[@]}" | sort)
fi

# ── Step 2: Transcribe ────────────────────────────────────────────────────────
echo ""
echo "── Step 2: Transcribe ──────────────────────────────────────────────────────"

# 4-bit quantized: ~463 MB on disk, much lower memory than the full model (~1.6 GB),
# negligible accuracy loss. Better fit for 8 GB unified memory.
MLX_MODEL="mlx-community/whisper-large-v3-turbo-4bit"

FILES_PROCESSED=0
for FILE in "${WAV_FILES[@]}"; do
  NAME="${FILE%.wav}"
  echo "  Transcribing $FILE..."
  FILE_START=$(date +%s)

  # Output to a temp dir so we can pick only .srt and .txt
  TMPDIR=$(mktemp -d)
  mlx_whisper "$FILE" \
    --model "$MLX_MODEL" \
    --language "$LANG_CODE" \
    --output-format all \
    --output-name "$NAME" \
    --output-dir "$TMPDIR" \
    --condition-on-previous-text False \
    --verbose False

  mv "$TMPDIR/${NAME}.srt" "./${NAME}.srt"
  mv "$TMPDIR/${NAME}.txt" "./${NAME}.txt"
  rm -rf "$TMPDIR"

  FILE_END=$(date +%s)
  echo "  Done in $((FILE_END - FILE_START))s → ${NAME}.srt, ${NAME}.txt"
  FILES_PROCESSED=$((FILES_PROCESSED + 1))
done

# ── Step 3: Correct (optional) ────────────────────────────────────────────────
if [[ "$CORRECT" == true ]]; then
  echo ""
  echo "── Step 3: Correct ─────────────────────────────────────────────────────────"
  CORRECT_ARGS=()
  [[ -n "$CONTEXT_STR" ]] && CORRECT_ARGS+=(--context "$CONTEXT_STR")
  "$SCRIPT_DIR/lec-correct" "${CORRECT_ARGS[@]}"
fi

# ── Summary ───────────────────────────────────────────────────────────────────
SCRIPT_END=$(date +%s)
TOTAL=$((SCRIPT_END - SCRIPT_START))

STEPS="transcribe"
[[ "$RENAME"   == true ]] && STEPS="rename, $STEPS"
[[ "$CORRECT"  == true ]] && STEPS="$STEPS, correct"

echo ""
echo "── Summary ─────────────────────────────────────────────────────────────────"
printf "  %-18s %s\n" "Files processed:" "$FILES_PROCESSED"
printf "  %-18s %s\n" "Steps run:"       "$STEPS"
printf "  %-18s %s\n" "Language:"        "$LANG_CODE  (model: $MLX_MODEL)"
printf "  %-18s %s\n" "Total time:"      "${TOTAL}s"
