#!/usr/bin/env bash
# lec-process — rename, optionally normalize, and transcribe lecture WAV files
# Usage: lec-process [--normalize|-n] [--lang LANGCODE]
# Run from inside the lecture folder (e.g. "260402 feminism")
set -euo pipefail

# ── Defaults ───────────────────────────────────────────────────────────────────
NORMALIZE=false
LANG_CODE="en"

# ── Argument parsing ───────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --normalize|-n)
      NORMALIZE=true
      shift
      ;;
    --lang)
      [[ $# -lt 2 ]] && { echo "Error: --lang requires a language code (e.g. --lang nl)"; exit 1; }
      LANG_CODE="$2"
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: lec-process [--normalize|-n] [--lang LANGCODE]"
      exit 1
      ;;
  esac
done

# ── Dependency checks ──────────────────────────────────────────────────────────
if ! command -v ffmpeg &>/dev/null; then
  echo "Error: ffmpeg not found. Install with: brew install ffmpeg"
  exit 1
fi
if ! command -v whisper-cli &>/dev/null; then
  echo "Error: whisper-cli not found. Install with: brew install whisper-cpp"
  exit 1
fi

# ── Collect WAV files, sorted alphabetically ──────────────────────────────────
WAV_FILES=()
while IFS= read -r f; do
  WAV_FILES+=("$f")
done < <(find . -maxdepth 1 -iname "*.wav" | sed 's|^\./||' | sort)

if [[ ${#WAV_FILES[@]} -eq 0 ]]; then
  echo "Error: no .wav files found in the current directory."
  exit 1
fi

FOLDER_NAME="$(basename "$PWD")"
SCRIPT_START=$(date +%s)

# ── Step 1: Rename ────────────────────────────────────────────────────────────
echo ""
echo "── Step 1: Rename ──────────────────────────────────────────────────────────"

INDEX=1
RENAMED=()
for FILE in "${WAV_FILES[@]}"; do
  TARGET="${FOLDER_NAME}_${INDEX}.wav"
  if [[ "$FILE" == "$TARGET" ]]; then
    echo "  [skip] $FILE"
  else
    mv "$FILE" "$TARGET"
    echo "  $FILE → $TARGET"
  fi
  RENAMED+=("$TARGET")
  INDEX=$((INDEX + 1))
done

# Re-sort after rename (names are now deterministic)
SORTED=()
while IFS= read -r f; do
  SORTED+=("$f")
done < <(printf '%s\n' "${RENAMED[@]}" | sort)

# ── Normalize helper ───────────────────────────────────────────────────────────
# Two-pass loudnorm: measure in pass 1, apply linear correction in pass 2.
normalize_file() {
  local FILE="$1"
  echo "  Analyzing $FILE..."

  # Pass 1 — capture loudness measurements from ffmpeg stderr
  local STATS
  STATS=$(ffmpeg -i "$FILE" \
    -af "loudnorm=I=-16:TP=-1:LRA=9:print_format=json" \
    -f null - 2>&1)

  local input_i input_tp input_lra input_thresh target_offset
  input_i=$(      echo "$STATS" | awk -F'"' '/"input_i"/      {print $4}')
  input_tp=$(     echo "$STATS" | awk -F'"' '/"input_tp"/     {print $4}')
  input_lra=$(    echo "$STATS" | awk -F'"' '/"input_lra"/    {print $4}')
  input_thresh=$( echo "$STATS" | awk -F'"' '/"input_thresh"/ {print $4}')
  target_offset=$(echo "$STATS" | awk -F'"' '/"target_offset"/{print $4}')

  echo "  Applying normalization to $FILE..."
  local TMPFILE="${FILE%.wav}_loudnorm_tmp.wav"

  # Pass 2 — apply measured correction with linear mode
  ffmpeg -y -i "$FILE" \
    -af "loudnorm=I=-16:TP=-1:LRA=9:\
measured_I=${input_i}:measured_TP=${input_tp}:measured_LRA=${input_lra}:\
measured_thresh=${input_thresh}:offset=${target_offset}:\
linear=true:print_format=summary" \
    "$TMPFILE" 2>/dev/null

  mv "$TMPFILE" "$FILE"
  echo "  Done: $FILE"
}

# ── Step 2: Normalize (optional) ──────────────────────────────────────────────
if [[ "$NORMALIZE" == true ]]; then
  echo ""
  echo "── Step 2: Normalize (-16 LUFS / -1 dBTP / LRA 9) ─────────────────────────"
  for FILE in "${SORTED[@]}"; do
    normalize_file "$FILE"
  done
fi

# ── Step 3: Transcribe ────────────────────────────────────────────────────────
echo ""
echo "── Step 3: Transcribe ──────────────────────────────────────────────────────"

MODELS_DIR="$(brew --prefix)/share/whisper-cpp/models"

# English-only model is smaller and more accurate for English
if [[ "$LANG_CODE" == "en" ]]; then
  MODEL="ggml-medium.en.bin"
else
  MODEL="ggml-medium.bin"
fi

MODEL_PATH="${MODELS_DIR}/${MODEL}"

if [[ ! -f "$MODEL_PATH" ]]; then
  echo "Error: model not found at $MODEL_PATH"
  echo "Download with: whisper-cpp-download-ggml-model medium${LANG_CODE:+"."}${LANG_CODE/#en/}"
  exit 1
fi

FILES_PROCESSED=0
for FILE in "${SORTED[@]}"; do
  NAME="${FILE%.wav}"
  echo "  Transcribing $FILE..."
  FILE_START=$(date +%s)

  # Metal GPU is enabled by default on Apple Silicon; -t sets CPU thread count
  whisper-cli \
    -m "$MODEL_PATH" \
    -f "$FILE" \
    -l "$LANG_CODE" \
    -t 4 \
    --output-srt \
    --output-txt \
    --output-file "$NAME"

  FILE_END=$(date +%s)
  echo "  Done in $((FILE_END - FILE_START))s → ${NAME}.srt, ${NAME}.txt"
  FILES_PROCESSED=$((FILES_PROCESSED + 1))
done

# ── Summary ───────────────────────────────────────────────────────────────────
SCRIPT_END=$(date +%s)
TOTAL=$((SCRIPT_END - SCRIPT_START))

STEPS="rename, transcribe"
[[ "$NORMALIZE" == true ]] && STEPS="rename, normalize, transcribe"

echo ""
echo "── Summary ─────────────────────────────────────────────────────────────────"
printf "  %-18s %s\n" "Files processed:" "$FILES_PROCESSED"
printf "  %-18s %s\n" "Steps run:"       "$STEPS"
printf "  %-18s %s\n" "Language:"        "$LANG_CODE  (model: $MODEL)"
printf "  %-18s %s\n" "Total time:"      "${TOTAL}s"
